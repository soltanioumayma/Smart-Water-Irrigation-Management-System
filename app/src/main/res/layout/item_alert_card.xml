<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="@color/bg_dark_card"
    app:cardElevation="4dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/bleu_fauchiat">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Barre colorée de sévérité (gauche) -->
        <View
            android:id="@+id/severityBar"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/status_danger"
            android:layout_marginEnd="14dp" />

        <!-- Contenu principal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Titre + Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvAlertMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚠️ pH trop acide"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_white" />

                <TextView
                    android:id="@+id/tvAlertParameter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pH"
                    android:textSize="11sp"
                    android:textColor="@color/text_white"
                    android:background="@drawable/bg_badge_parameter"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Valeur actuelle et seuil -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvAlertValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Valeur: 5.2"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | Seuil: 6.5"
                    android:textSize="12sp"
                    android:textColor="@color/status_danger"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Description courte -->
            <TextView
                android:id="@+id/tvAlertDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="L'eau est trop acide pour l'irrigation..."
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- Bouton détails (droite) -->
        <ImageButton
            android:id="@+id/btnAlertDetails"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_button_round"
            android:src="@drawable/ic_arrow_right"
            android:scaleType="centerInside"
            android:contentDescription="Voir détails"
            android:layout_marginStart="12dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>